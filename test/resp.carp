(load "../redis.carp")
(load "Test.carp")
(use Test)

(defn decode-ok? [s] (Result.success? &(RESP.from-string s)))

(defn decode-err? [s] (Result.error? &(RESP.from-string s)))

(defn roundtrip [r]
  (let [encoded (str r)]
    (match (RESP.from-string &encoded)
      (Result.Success decoded) (str &decoded)
      (Result.Error e) (fmt "ROUNDTRIP_FAIL: %s" &e))))

(deftest test
  (assert-equal test "$-1\r\n" &(str &(RESP.Null)) "encode Null")

  (assert-equal test "$5\r\nhello\r\n" &(str &(RESP.Str @"hello")) "encode Str")

  (assert-equal test "$0\r\n\r\n" &(str &(RESP.Str @"")) "encode empty Str")

  (assert-equal test
    "$11\r\nhello world\r\n"
    &(str &(RESP.Str @"hello world"))
    "encode Str with space")

  (assert-equal test
    "-ERR unknown\r\n"
    &(str &(RESP.Err @"ERR unknown"))
    "encode Err")

  (assert-equal test "-\r\n" &(str &(RESP.Err @"")) "encode empty Err")

  (assert-equal test ":42\r\n" &(str &(RESP.Integer 42)) "encode Integer 42")

  (assert-equal test ":0\r\n" &(str &(RESP.Integer 0)) "encode Integer 0")

  (assert-equal test
    ":-1\r\n"
    &(str &(RESP.Integer -1))
    "encode negative Integer")

  (assert-equal test
    ":1000000\r\n"
    &(str &(RESP.Integer 1000000))
    "encode large Integer")

  (assert-equal test
    "*0\r\n"
    &(str &(RESP.Arr (the (Array (Box RESP)) [])))
    "encode empty Arr")

  (assert-equal test
    "*1\r\n$2\r\nhi\r\n"
    &(str &(RESP.Arr [(Box.init (RESP.Str @"hi"))]))
    "encode single-element Arr")

  (assert-equal test
    "*2\r\n$3\r\nfoo\r\n$3\r\nbar\r\n"
    &(str
      &(RESP.Arr [(Box.init (RESP.Str @"foo")) (Box.init (RESP.Str @"bar"))]))
    "encode two-element Arr")

  (assert-equal test
    "*3\r\n$2\r\nhi\r\n:42\r\n$-1\r\n"
    &(str
      &(RESP.Arr
        [(Box.init (RESP.Str @"hi"))
         (Box.init (RESP.Integer 42))
         (Box.init (RESP.Null))]))
    "encode mixed-type Arr")

  (assert-equal test
    "*1\r\n*2\r\n:1\r\n:2\r\n"
    &(str
      &(RESP.Arr
        [(Box.init
           (RESP.Arr [(Box.init (RESP.Integer 1)) (Box.init (RESP.Integer 2))]))]))
    "encode nested Arr")

  (assert-equal test
    "*2\r\n*1\r\n$1\r\na\r\n*1\r\n$1\r\nb\r\n"
    &(str
      &(RESP.Arr
        [(Box.init (RESP.Arr [(Box.init (RESP.Str @"a"))]))
         (Box.init (RESP.Arr [(Box.init (RESP.Str @"b"))]))]))
    "encode array of arrays")

  (assert-true test
    (match (RESP.from-string "+OK\r\n")
      (Result.Success r) (match r (RESP.Str s) (= &s "OK") _ false)
      _ false)
    "decode simple string +OK")

  ; empty simple string "+\r\n" hits a String.index-of-from edge case
  ; (exclusive start position), so the decoder returns an error here.
  (assert-true test
    (match (RESP.from-string "+\r\n") (Result.Error _) true _ false)
    "decode empty simple string — known limitation")

  (assert-true test
    (match (RESP.from-string "+hello world\r\n")
      (Result.Success r) (match r (RESP.Str s) (= &s "hello world") _ false)
      _ false)
    "decode simple string with spaces")

  (assert-true test
    (match (RESP.from-string "-ERR unknown command\r\n")
      (Result.Success r)
        (match r (RESP.Err s) (= &s "ERR unknown command") _ false)
      _ false)
    "decode error string")

  (assert-true test
    (match (RESP.from-string "-WRONGTYPE Operation against a key\r\n")
      (Result.Success r)
        (match r (RESP.Err s) (= &s "WRONGTYPE Operation against a key") _ false)
      _ false)
    "decode long error message")

  (assert-true test
    (match (RESP.from-string ":42\r\n")
      (Result.Success r) (match r (RESP.Integer i) (= i 42) _ false)
      _ false)
    "decode integer 42")

  (assert-true test
    (match (RESP.from-string ":0\r\n")
      (Result.Success r) (match r (RESP.Integer i) (= i 0) _ false)
      _ false)
    "decode integer 0")

  (assert-true test
    (match (RESP.from-string ":-1\r\n")
      (Result.Success r) (match r (RESP.Integer i) (= i -1) _ false)
      _ false)
    "decode negative integer")

  (assert-true test
    (match (RESP.from-string ":1000000\r\n")
      (Result.Success r) (match r (RESP.Integer i) (= i 1000000) _ false)
      _ false)
    "decode large integer")

  (assert-true test
    (match (RESP.from-string "$6\r\nfoobar\r\n")
      (Result.Success r) (match r (RESP.Str s) (= &s "foobar") _ false)
      _ false)
    "decode bulk string")

  (assert-true test
    (match (RESP.from-string "$0\r\n\r\n")
      (Result.Success r) (match r (RESP.Str s) (= &s "") _ false)
      _ false)
    "decode empty bulk string")

  (assert-true test
    (match (RESP.from-string "$-1\r\n")
      (Result.Success r) (match r (RESP.Null) true _ false)
      _ false)
    "decode null bulk string")

  (assert-true test
    (match (RESP.from-string "$12\r\nhello\r\nworld\r\n")
      (Result.Success r) (match r (RESP.Str s) (= &s "hello\r\nworld") _ false)
      _ false)
    "decode bulk string containing CRLF")

  (assert-true test
    (match (RESP.from-string "*0\r\n")
      (Result.Success r) (match r (RESP.Arr a) (= (Array.length &a) 0) _ false)
      _ false)
    "decode empty array")

  (assert-true test
    (match (RESP.from-string "*-1\r\n")
      (Result.Success r) (match r (RESP.Null) true _ false)
      _ false)
    "decode null array")

  (assert-true test
    (match (RESP.from-string "*1\r\n+OK\r\n")
      (Result.Success r)
        (match r
          (RESP.Arr a)
            (and (= (Array.length &a) 1)
                 (match @(Box.peek (Array.unsafe-nth &a 0))
                   (RESP.Str s) (= &s "OK")
                   _ false))
          _ false)
      _ false)
    "decode single-element array")

  (assert-true test
    (match (RESP.from-string "*2\r\n$3\r\nfoo\r\n$3\r\nbar\r\n")
      (Result.Success r)
        (match r
          (RESP.Arr a)
            (and (= (Array.length &a) 2)
                 (match @(Box.peek (Array.unsafe-nth &a 0))
                   (RESP.Str s) (= &s "foo")
                   _ false))
          _ false)
      _ false)
    "decode two bulk strings in array")

  (assert-true test
    (match (RESP.from-string "*3\r\n:1\r\n:2\r\n:3\r\n")
      (Result.Success r)
        (match r
          (RESP.Arr a)
            (and (= (Array.length &a) 3)
                 (match @(Box.peek (Array.unsafe-nth &a 1))
                   (RESP.Integer i) (= i 2)
                   _ false))
          _ false)
      _ false)
    "decode integer array, check middle element")

  (assert-true test
    (match (RESP.from-string "*3\r\n+OK\r\n:42\r\n$-1\r\n")
      (Result.Success r)
        (match r
          (RESP.Arr a)
            (and (= (Array.length &a) 3)
                 (and
                   (match @(Box.peek (Array.unsafe-nth &a 0))
                     (RESP.Str s) (= &s "OK")
                     _ false)
                   (and
                     (match @(Box.peek (Array.unsafe-nth &a 1))
                       (RESP.Integer i) (= i 42)
                       _ false)
                     (match @(Box.peek (Array.unsafe-nth &a 2))
                       (RESP.Null) true
                       _ false))))
          _ false)
      _ false)
    "decode mixed-type array: Str, Integer, Null")

  (assert-true test
    (match (RESP.from-string "*2\r\n*2\r\n:1\r\n:2\r\n*2\r\n:3\r\n:4\r\n")
      (Result.Success r)
        (match r
          (RESP.Arr outer)
            (and (= (Array.length &outer) 2)
                 (and
                   (match @(Box.peek (Array.unsafe-nth &outer 0))
                     (RESP.Arr inner) (= (Array.length &inner) 2)
                     _ false)
                   (match @(Box.peek (Array.unsafe-nth &outer 1))
                     (RESP.Arr inner) (= (Array.length &inner) 2)
                     _ false)))
          _ false)
      _ false)
    "decode nested arrays")

  (assert-true test
    (match (RESP.from-string "*1\r\n*1\r\n*1\r\n:99\r\n")
      (Result.Success r)
        (match r
          (RESP.Arr l1)
            (match @(Box.peek (Array.unsafe-nth &l1 0))
              (RESP.Arr l2)
                (match @(Box.peek (Array.unsafe-nth &l2 0))
                  (RESP.Arr l3)
                    (match @(Box.peek (Array.unsafe-nth &l3 0))
                      (RESP.Integer i) (= i 99)
                      _ false)
                  _ false)
              _ false)
          _ false)
      _ false)
    "decode three levels of nesting")

  (assert-true test
    (match (RESP.from-string "*2\r\n-ERR oops\r\n:1\r\n")
      (Result.Success r)
        (match r
          (RESP.Arr a)
            (and (= (Array.length &a) 2)
                 (match @(Box.peek (Array.unsafe-nth &a 0))
                   (RESP.Err s) (= &s "ERR oops")
                   _ false))
          _ false)
      _ false)
    "decode array containing error element")

  (assert-true test
    (match (RESP.from-string "")
      (Result.Success r) (match r (RESP.Null) true _ false)
      _ false)
    "empty input decodes to Null")

  (assert-true test
    (match (RESP.from-string "+OK\r\n:42\r\n")
      (Result.Success r) (match r (RESP.Str s) (= &s "OK") _ false)
      _ false)
    "trailing data after first value is ignored")

  (assert-true test (decode-err? "+no crlf") "reject simple string without CRLF")

  (assert-true test (decode-err? "-no crlf") "reject error without CRLF")

  (assert-true test (decode-err? ":no crlf") "reject integer without CRLF")

  (assert-true test (decode-err? ":notanumber\r\n") "reject non-numeric integer")

  (assert-true test
    (decode-err? "$abc\r\ndata\r\n")
    "reject bulk string with non-numeric length")

  (assert-true test
    (decode-err? "$\r\ndata\r\n")
    "reject bulk string with missing length")

  (assert-true test
    (decode-err? "*abc\r\n")
    "reject array with non-numeric count")

  (assert-true test (decode-err? "%garbage\r\n") "reject unknown type prefix")

  (assert-true test
    (decode-err? "~anything\r\n")
    "reject another unknown type prefix")

  (assert-equal test "$-1\r\n" &(roundtrip &(RESP.Null)) "Null roundtrip")

  (assert-equal test
    "$5\r\nhello\r\n"
    &(roundtrip &(RESP.Str @"hello"))
    "Str roundtrip")

  (assert-equal test
    "$0\r\n\r\n"
    &(roundtrip &(RESP.Str @""))
    "empty Str roundtrip")

  (assert-equal test
    "-ERR test\r\n"
    &(roundtrip &(RESP.Err @"ERR test"))
    "Err roundtrip")

  (assert-equal test
    ":42\r\n"
    &(roundtrip &(RESP.Integer 42))
    "Integer roundtrip")

  (assert-equal test
    ":-1\r\n"
    &(roundtrip &(RESP.Integer -1))
    "negative Integer roundtrip")

  (assert-equal test
    "*0\r\n"
    &(roundtrip &(RESP.Arr (the (Array (Box RESP)) [])))
    "empty Arr roundtrip")

  (assert-equal test
    "*2\r\n$3\r\nfoo\r\n$3\r\nbar\r\n"
    &(roundtrip
      &(RESP.Arr [(Box.init (RESP.Str @"foo")) (Box.init (RESP.Str @"bar"))]))
    "Str Arr roundtrip")

  (assert-equal test
    "*3\r\n$2\r\nhi\r\n:42\r\n$-1\r\n"
    &(roundtrip
      &(RESP.Arr
        [(Box.init (RESP.Str @"hi"))
         (Box.init (RESP.Integer 42))
         (Box.init (RESP.Null))]))
    "mixed Arr roundtrip")

  (assert-equal test
    "*1\r\n*2\r\n:1\r\n:2\r\n"
    &(roundtrip
      &(RESP.Arr
        [(Box.init
           (RESP.Arr [(Box.init (RESP.Integer 1)) (Box.init (RESP.Integer 2))]))]))
    "nested Arr roundtrip")

  (assert-equal test
    "$5\r\nhello\r\n"
    &(str &(String.to-redis @"hello"))
    "to-redis String")

  (assert-equal test ":42\r\n" &(str &(Int.to-redis 42)) "to-redis Int")

  (assert-true test
    (let [r (RESP.decode-n "+OK\r\n" 1)]
      (and (= (Array.length &r) 1)
           (match @(Array.unsafe-nth &r 0) (RESP.Str s) (= &s "OK") _ false)))
    "decode-n: single value")

  (assert-true test
    (let [r (RESP.decode-n "+OK\r\n:42\r\n" 2)]
      (and (= (Array.length &r) 2)
           (and
             (match @(Array.unsafe-nth &r 0) (RESP.Str s) (= &s "OK") _ false)
             (match @(Array.unsafe-nth &r 1) (RESP.Integer i) (= i 42) _ false))))
    "decode-n: two values")

  (assert-true test
    (let [r (RESP.decode-n "+OK\r\n:42\r\n$5\r\nhello\r\n" 3)]
      (and (= (Array.length &r) 3)
           (match @(Array.unsafe-nth &r 2) (RESP.Str s) (= &s "hello") _ false)))
    "decode-n: three mixed values")

  (assert-equal test
    0
    (Array.length &(RESP.decode-n "" 5))
    "decode-n: empty string returns empty array")

  (assert-true test
    (= (Array.length &(RESP.decode-n "+OK\r\n" 3)) 1)
    "decode-n: fewer values than requested")

  (assert-true test
    (let [r (RESP.decode-n "+OK\r\n+PONG\r\n+OK\r\n:100\r\n$3\r\nfoo\r\n" 5)]
      (= (Array.length &r) 5))
    "decode-n: five values")

  (assert-true test
    (let [r (RESP.decode-n "$-1\r\n$-1\r\n" 2)]
      (and (= (Array.length &r) 2)
           (and
             (match @(Array.unsafe-nth &r 0) (RESP.Null) true _ false)
             (match @(Array.unsafe-nth &r 1) (RESP.Null) true _ false))))
    "decode-n: multiple nulls")

  (assert-true test
    (let [r (RESP.decode-n "+OK\r\n+trun" 2)] (= (Array.length &r) 1))
    "decode-n: truncated second value returns only complete values")

  (assert-equal test
    0
    @(RedisPipeline.count &(RedisPipeline.begin))
    "pipeline begin creates empty pipeline")

  (assert-true test
    (let-do [p (RedisPipeline.begin)]
      (RedisPipeline.add &p @"SET" &[(to-redis @"k") (to-redis @"v")])
      (= @(RedisPipeline.count &p) 1))
    "pipeline add increments count")

  (assert-true test
    (let-do [p (RedisPipeline.begin)]
      (RedisPipeline.add &p @"SET" &[(to-redis @"k") (to-redis @"v")])
      (RedisPipeline.add &p @"GET" &[(to-redis @"k")])
      (= @(RedisPipeline.count &p) 2))
    "pipeline add increments count for each command")

  (assert-equal test
    "*3\r\n$3\r\nSET\r\n$1\r\nk\r\n$1\r\nv\r\n"
    &(StringBuf.str
      (RedisPipeline.buf
        &(let-do [p (RedisPipeline.begin)]
          (RedisPipeline.add &p @"SET" &[(to-redis @"k") (to-redis @"v")])
          p)))
    "pipeline add encodes SET as RESP array")

  (assert-equal test
    "*2\r\n$3\r\nGET\r\n$3\r\nfoo\r\n"
    &(StringBuf.str
      (RedisPipeline.buf
        &(let-do [p (RedisPipeline.begin)]
          (RedisPipeline.add &p @"GET" &[(to-redis @"foo")])
          p)))
    "pipeline add encodes GET as RESP array")

  (assert-true test
    (let-do [p (RedisPipeline.begin)]
      (RedisPipeline.add &p @"SET" &[(to-redis @"a") (to-redis @"1")])
      (RedisPipeline.add &p @"SET" &[(to-redis @"b") (to-redis @"2")])
      (= &(StringBuf.str (RedisPipeline.buf &p))
         "*3\r\n$3\r\nSET\r\n$1\r\na\r\n$1\r\n1\r\n*3\r\n$3\r\nSET\r\n$1\r\nb\r\n$1\r\n2\r\n"))
    "pipeline add concatenates multiple commands")

  (assert-true test
    (let-do [p (RedisPipeline.begin)]
      (RedisPipeline.add &p @"PING" &(the (Array RESP) []))
      (= &(StringBuf.str (RedisPipeline.buf &p)) "*1\r\n$4\r\nPING\r\n"))
    "pipeline add handles command with no args")

  (assert-equal test
    0
    (StringBuf.length (RedisPipeline.buf &(RedisPipeline.begin)))
    "pipeline begin has empty buffer"))
