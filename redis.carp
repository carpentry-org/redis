(load "git@github.com:carpentry-org/socket@0.2.1")
(load "git@github.com:carpentry-org/strbuf@0.1.0")

(deftype RESP
  (Null [])
  (Str [String])
  (Err [String])
  (Integer [Int])
  (Arr [(Array (Box RESP))]))

(defmodule RESP
  (use-all Array Maybe Pattern Result)

  (defn str [r]
    (match @r
      (Null) @"$-1\r\n"
      (Str s) (fmt "$%d\r\n%s\r\n" (String.length &s) &s)
      (Err s) (fmt "-%s\r\n" &s)
      (Integer i) (fmt ":%d\r\n" i)
      (Arr a)
        (let-do [parts [(fmt "*%d\r\n" (Array.length &a))]]
          (for [i 0 (Array.length &a)]
            (Array.push-back! &parts (str (Box.peek (Array.unsafe-nth &a i)))))
          (String.concat &parts))))

  (hidden decode-one)
  (private decode-one)
  (defn decode-one [s pos]
    ; out of input mid-value: error rather than pad the array with a phantom Null
    (if (>= pos (String.length s))
      (Error @"Unexpected end of RESP input")
      (case (String.char-at s pos)
            \+
            (let [rest-start (+ pos 1)
                  idx (String.index-of-from s \return rest-start)]
              (if (= idx -1)
                (Error @"Malformed simple string")
                (Success
                  (Pair.init
                    (Str (String.byte-slice s rest-start idx))
                    (+ idx 2)))))
            \-
            (let [rest-start (+ pos 1)
                  idx (String.index-of-from s \return rest-start)]
              (if (= idx -1)
                (Error @"Malformed error string")
                (Success
                  (Pair.init
                    (Err (String.byte-slice s rest-start idx))
                    (+ idx 2)))))
            \:
            (let [rest-start (+ pos 1)
                  idx (String.index-of-from s \return rest-start)]
              (if (= idx -1)
                (Error @"Malformed integer")
                (match (Int.from-string &(String.byte-slice s rest-start idx))
                  (Maybe.Nothing) (Error @"Could not parse integer in result.")
                  (Maybe.Just n) (Success (Pair.init (Integer n) (+ idx 2))))))
            \$
            (let [rest-start (+ pos 1)
                  idx (String.index-of-from s \return rest-start)]
              (if (= idx -1)
                (Error @"Malformed bulk string")
                (match (Int.from-string &(String.byte-slice s rest-start idx))
                  (Maybe.Nothing)
                    (Error
                      @"Error decoding bulk string: does not start with length!")
                  (Maybe.Just len)
                    (let [data-start (+ idx 2)
                          available (- (String.length s) data-start)]
                      (cond
                        (= len -1)
                        (Success (Pair.init (Null) data-start))
                        (< len 0)
                        (Error @"Malformed bulk string: negative length")
                        ; payload + trailing CRLF must be present; comparing len
                        ; alone avoids overflow on a huge declared length
                        (> len (- available 2))
                        (Error @"Incomplete bulk string")
                        (Success
                          (Pair.init
                            (Str
                              (String.byte-slice s data-start (+ data-start len)))
                            (+ data-start (+ len 2)))))))))
            \*
            (let [rest-start (+ pos 1)
                  idx (String.index-of-from s \return rest-start)]
              (if (= idx -1)
                (Error @"Malformed array")
                (match (Int.from-string &(String.byte-slice s rest-start idx))
                  (Maybe.Nothing)
                    (Error @"Error decoding array: does not start with length!")
                  (Maybe.Just len)
                    (cond
                      (= len -1)
                      (Success (Pair.init (Null) (+ idx 2)))
                      (= len 0)
                      (Success (Pair.init (Arr []) (+ idx 2)))
                      ; build incrementally so the error path frees only decoded
                      ; boxes, never uninitialized slots
                      (let-do [cur (+ idx 2)
                               a []
                               err @""]
                        (for [i 0 len]
                          (match (decode-one s cur)
                            (Result.Error e) (do (set! err e) (break))
                            (Result.Success p)
                              (do
                                (Array.push-back! &a (Box.init @(Pair.a &p)))
                                (set! cur @(Pair.b &p)))))
                        (if (= &err "")
                          (Success (Pair.init (Arr a) cur))
                          (Error err)))))))
            (Error
              (fmt "Malformed RESP data: got %s"
                   &(String.byte-slice s pos (+ pos 1)))))))

  (doc from-string "converts a RESP string into a `RESP` data structure.")
  (defn from-string [s]
    (if (empty? s)
      (Success (Null))
      (match (decode-one s 0)
        (Result.Error e) (Error e)
        (Result.Success p) (Success @(Pair.a &p)))))

  (doc decode-n "decodes up to `n` RESP values from string `s`.

Returns an array of the values that could be successfully decoded. If the
array has fewer than `n` elements, the string did not contain enough
complete RESP data.")
  (defn decode-n [s n]
    (let-do [results []
             pos 0]
      (for [i 0 n]
        (if (>= pos (String.length s))
          (break)
          (match (decode-one s pos)
            (Result.Error _e) (break)
            (Result.Success p)
              (if (<= @(Pair.b &p) pos)
                (break)
                (do
                  (Array.push-back! &results @(Pair.a &p))
                  (set! pos @(Pair.b &p)))))))
      results))

  (definterface to-redis (Fn [a] RESP)))

(defmodule String
  (defn to-redis [s] (RESP.Str s))
  (implements to-redis String.to-redis))

(defmodule Int
  (defn to-redis [s] (RESP.Integer s))
  (implements to-redis Int.to-redis))

(deftype Redis [sock TcpStream])

(defmodule Redis
  (use-all Array Result)

  (doc open-on "opens the connection to Redis on port `port`.")
  (defn open-on [host port]
    (match (TcpStream.connect host port)
      (Result.Success s) (Success (init s))
      (Result.Error e)
        (Error (fmt "Couldn’t connect to %s:%d: %s" host port &e))))

  (doc open "opens the connection to Redis on port 6379.

For variable port numbers please check out [`open-on`](#open-on).")
  (defn open [host] (open-on host 6379))

  (doc read "reads a `RESP` object from Redis.

Accumulates data across multiple socket reads until a complete RESP
value has been received.")
  (defn read [r]
    (let-do [acc @""
             results (the (Array RESP) [])]
      (while (< (Array.length &results) 1)
        (match (the (Result String String) (TcpStream.read (sock r)))
          (Result.Error e) (do (set! acc e) (break))
          (Result.Success s)
            (if (String.empty? &s)
              (do (set! acc @"connection closed") (break))
              (do
                (set! acc (String.concat &[acc s]))
                (set! results (RESP.decode-n &acc 1))))))
      (if (= (Array.length &results) 1)
        (Result.Success @(Array.unsafe-nth &results 0))
        (Result.Error acc))))

  (doc send "sends the command `cmd` with the arguments `args` to Redis.

Returns `(Result () String)`, propagating any socket errors.")
  (defn send [r cmd args]
    (let [cmd-parts (copy-map &(fn [x] (Box.init (to-redis @x)))
                              &(Pattern.split #" " &cmd))
          msg (str
            &(RESP.Arr
              (concat &[cmd-parts (copy-map &(fn [x] (Box.init @x)) args)])))]
      (match (TcpStream.send (sock r) &msg)
        (Result.Success _n) (Result.Success ())
        (Result.Error e) (Result.Error e))))

  (doc close "closes the connection to Redis.")
  (defn close [r] (TcpStream.close @(sock &r))))

(deftype PubSubMessage
  (Message [String String])
  (PMessage [String String String])
  (Subscribe [String Int])
  (Unsubscribe [String Int])
  (PSubscribe [String Int])
  (PUnsubscribe [String Int]))

(defmodule PubSubMessage
  (hidden str-at)
  (private str-at)
  (defn str-at [a i]
    (match-ref (Box.peek (Array.unsafe-nth a i))
      (RESP.Str s) (Result.Success @s)
      _ (Result.Error @"expected a bulk-string field in pub/sub reply")))

  (hidden int-at)
  (private int-at)
  (defn int-at [a i]
    (match-ref (Box.peek (Array.unsafe-nth a i))
      (RESP.Integer n) (Result.Success @n)
      _ (Result.Error @"expected an integer field in pub/sub reply")))

  (hidden decode-sub)
  (private decode-sub)
  (defn decode-sub [a n]
    (if (= n 3)
      (match (str-at a 1)
        (Result.Error e) (Result.Error e)
        (Result.Success name)
          (match (int-at a 2)
            (Result.Error e) (Result.Error e)
            (Result.Success count) (Result.Success (Pair.init name count))))
      (Result.Error @"malformed subscription reply: expected 3 elements")))

  (hidden decode-plain)
  (private decode-plain)
  (defn decode-plain [a n]
    (if (= n 3)
      (match (str-at a 1)
        (Result.Error e) (Result.Error e)
        (Result.Success channel)
          (match (str-at a 2)
            (Result.Error e) (Result.Error e)
            (Result.Success payload) (Result.Success (Message channel payload))))
      (Result.Error @"malformed message: expected 3 elements")))

  (hidden decode-pattern)
  (private decode-pattern)
  (defn decode-pattern [a n]
    (if (= n 4)
      (match (str-at a 1)
        (Result.Error e) (Result.Error e)
        (Result.Success pattern)
          (match (str-at a 2)
            (Result.Error e) (Result.Error e)
            (Result.Success channel)
              (match (str-at a 3)
                (Result.Error e) (Result.Error e)
                (Result.Success payload)
                  (Result.Success (PMessage pattern channel payload)))))
      (Result.Error @"malformed pmessage: expected 4 elements")))

  (doc decode-message
    "decodes a pushed pub/sub reply `r` into a `PubSubMessage`.

The reply is expected to be a `RESP.Arr` whose first element is a bulk string
naming the kind (`message`, `pmessage`, `subscribe`, `unsubscribe`,
`psubscribe` or `punsubscribe`). Returns an `Error` for any other RESP shape,
an unknown kind, a wrong element count, or a field of the wrong type.")
  (defn decode-message [r]
    (match-ref r
      (RESP.Arr a)
        (let [n (Array.length a)]
          (if (= n 0)
            (Result.Error @"empty pub/sub reply array")
            (match-ref (Box.peek (Array.unsafe-nth a 0))
              (RESP.Str kind)
                (cond
                  (= kind "message") (decode-plain a n)
                  (= kind "pmessage") (decode-pattern a n)
                  (= kind "subscribe")
                    (match (decode-sub a n)
                      (Result.Success p)
                        (Result.Success (Subscribe @(Pair.a &p) @(Pair.b &p)))
                      (Result.Error e) (Result.Error e))
                  (= kind "unsubscribe")
                    (match (decode-sub a n)
                      (Result.Success p)
                        (Result.Success (Unsubscribe @(Pair.a &p) @(Pair.b &p)))
                      (Result.Error e) (Result.Error e))
                  (= kind "psubscribe")
                    (match (decode-sub a n)
                      (Result.Success p)
                        (Result.Success (PSubscribe @(Pair.a &p) @(Pair.b &p)))
                      (Result.Error e) (Result.Error e))
                  (= kind "punsubscribe")
                    (match (decode-sub a n)
                      (Result.Success p)
                        (Result.Success (PUnsubscribe @(Pair.a &p) @(Pair.b &p)))
                      (Result.Error e) (Result.Error e))
                  (Result.Error (fmt "unrecognized pub/sub reply kind: %s" kind)))
              _ (Result.Error @"pub/sub reply kind is not a bulk string"))))
      _ (Result.Error @"pub/sub reply is not an array"))))

(defmodule Redis
  (doc next-message "reads the next pushed pub/sub reply and decodes it.

Blocks until one complete `RESP` value has been received (see [`read`](#read)),
then pipes it through [`PubSubMessage.decode-message`](#decode-message).
Propagates read errors and decoding errors as an `Error`.")
  (defn next-message [r]
    (match (read r)
      (Result.Error e) (Result.Error e)
      (Result.Success resp) (PubSubMessage.decode-message &resp)))

  (doc listen "repeatedly reads pub/sub replies, passing each decoded
`PubSubMessage` to `callback` until an error occurs.

Loops on [`next-message`](#next-message), invoking `callback` by reference for
every message, until a read or decode error is returned — e.g. the connection
is closed. That terminating error is returned to the caller.")
  (defn listen [r callback]
    (let-do [err @""
             running true]
      (while running
        (match (next-message r)
          (Result.Error e) (do (set! err e) (set! running false))
          (Result.Success msg) (~callback &msg)))
      (the (Result () String) (Result.Error err)))))

(defndynamic rtreat- [s]
  (let [i (String.index-of s \-)]
    (if (= i -1)
      s
      (String.concat
        [(String.prefix s i) " " (rtreat- (String.suffix s (+ i 1)))]))))

(defndynamic rconv- [args]
  (if (= (length args) 0)
    (array)
    (cons (list 'to-redis (car args)) (rconv- (cdr args)))))

(defmacro defredis [cmd :rest args]
  (eval
    (list 'defmodule
          'Redis
          (list 'doc
                cmd
                (String.concat
                  ["is a wrapper around the `"
                   (rtreat- (Symbol.str cmd))
                   "` Redis command.

It takes the same arguments as the [Redis command](https://redis.io/commands/"
                   (Symbol.str cmd)
                   ")."]))
          (list 'defn
                cmd
                (collect-into (cons 'r args) array)
                (list 'match
                      (list 'Redis.send
                            'r
                            (list 'copy (rtreat- (Symbol.str cmd)))
                            (list 'ref (rconv- args)))
                      '(Result.Error e)
                      '(Result.Error e)
                      '(Result.Success _)
                      '(Redis.read r))))))

