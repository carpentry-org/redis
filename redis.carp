(deftype RedisPipeline [buf StringBuf
                        count Int])

(defmodule RedisPipeline
  (doc begin "creates a new empty pipeline.")
  (defn begin [] (init (StringBuf.create) 0))

  (doc add "adds a command to the pipeline.

The command name must use spaces to separate sub-commands (e.g.
`@\"CLIENT ID\"`, not `@\"client-id\"`). The [`with-pipeline`](#with-pipeline)
macro converts hyphens to spaces automatically, but `add` does not.")
  (defn add [p cmd args]
    (let-do [cmd-parts (Array.copy-map &(fn [x] (Box.init (to-redis @x)))
                                       &(Pattern.split #" " &cmd))
             msg (str
               &(RESP.Arr
                 (Array.concat
                   &[cmd-parts (Array.copy-map &(fn [x] (Box.init @x)) args)])))]
      (StringBuf.append-str (buf p) &msg)
      (set-count! p (+ @(count p) 1)))))

(defmodule Redis
  (hidden pipeline-read)
  (private pipeline-read)
  (defn pipeline-read [r n]
    (let-do [acc @""
             results (the (Array RESP) [])]
      (while (< (Array.length &results) (the Int n))
        (match (the (Result String String) (TcpStream.read (sock r)))
          (Result.Error e) (do (set! acc e) (break))
          (Result.Success s)
            (if (String.empty? &s)
              (do (set! acc @"connection closed") (break))
              (do
                (set! acc (String.concat &[acc s]))
                (set! results (RESP.decode-n &acc n))))))
      (if (= (Array.length &results) n)
        (Result.Success results)
        (Result.Error acc))))

  (doc pipeline-exec
    "sends all commands in the pipeline and reads all responses.

Returns `(Result (Array RESP) String)` with one RESP value per command,
in the order they were added.")
  (defn pipeline-exec [r p]
    (let [n @(RedisPipeline.count p)]
      (if (= n 0)
        (Result.Success (the (Array RESP) []))
        (match (TcpStream.send (sock r) &(StringBuf.str (RedisPipeline.buf p)))
          (Result.Error e) (Result.Error e)
          (Result.Success _) (pipeline-read r n))))))

(defndynamic pipeline-cmd- [cmd]
  (let [name (car cmd)
        args (cdr cmd)]
    (list 'RedisPipeline.add
          '(ref __pipeline)
          (list 'copy (rtreat- (Symbol.str name)))
          (list 'ref (collect-into (rconv- args) array)))))

(defndynamic pipeline-cmds- [cmds]
  (if (= (length cmds) 0)
    '()
    (cons (pipeline-cmd- (car cmds)) (pipeline-cmds- (cdr cmds)))))

(doc with-pipeline "batches Redis commands into a single pipeline.

Each form in the body is a command name followed by its arguments, using
the same naming convention as the individual wrappers (e.g. `set`, `get`,
`client-id`).

Returns `(Result (Array RESP) String)`.

```
(with-pipeline &r
  (set @\"key1\" @\"val1\")
  (set @\"key2\" @\"val2\")
  (get @\"key1\")
  (get @\"key2\"))
```")
(defmacro with-pipeline [r :rest cmds]
  (list 'let
        (array '__pipeline '(RedisPipeline.begin))
        (cons-last
          (list 'Redis.pipeline-exec r '(ref __pipeline))
          (cons 'do (pipeline-cmds- cmds)))))

(doc Redis "is a wrapper around Redis connections. It supports opening a
connection using [`open`](#open) or [`open-on`](#open-on), reading from and
sending to the connection (using [`read`](#read) and [`send`](#send),
respectively), and contains thin wrappers around all Redis commands through 7.2.

Commands can also be batched using [`pipeline-exec`](#pipeline-exec) or the
[`with-pipeline`](#with-pipeline) macro to reduce round-trip latency.

```
(match (Redis.open \"127.0.0.1\")
  (Result.Success r)
    (do
      (println* &(Redis.set &r @\"key\" @\"val\"))
      (println* &(Redis.get &r @\"key\"))
      (println* &(Redis.lrange &r @\"list\" @\"0\" @\"-1\"))
      (Redis.close r))
  (Result.Error err) (IO.errorln &err))
```")
(doc RESP "is a wrapper around the [Redis Serialization
Protocol](https://redis.io/topics/protocol). You can create all types,
stringify the built types into strings using [`str`](#str), decode single
values with [`from-string`](#from-string), and decode multiple concatenated
values with [`decode-n`](#decode-n). Arrays are fully supported, including
nested arrays.

```
; decoding
(RESP.from-string \"+OK\\r\\n\")       ; => (Success (Str @\"OK\"))
(RESP.from-string \":42\\r\\n\")       ; => (Success (Integer 42))
(RESP.from-string \"$-1\\r\\n\")       ; => (Success (Null))

; encoding
(str &(RESP.Str @\"hi\"))             ; => \"$2\\r\\nhi\\r\\n\"
(str &(RESP.Integer 42))            ; => \":42\\r\\n\"

; pattern matching on responses
(match (Redis.get &r @\"key\")
  (Result.Success resp)
    (match resp
      (RESP.Str s) (println* \"got: \" &s)
      (RESP.Null) (println* \"not found\")
      (RESP.Arr items) (println* \"array of \" &(Int.str (Array.length &items)))
      _ (println* \"other\"))
  (Result.Error e) (println* \"error: \" &e))
```

If you want your types to be supported when encoding, you’ll have to implement
the interface `to-redis`, the signature of which is `(Fn [a] RESP))`.")
(doc PubSubMessage "is the decoded form of a reply pushed to a subscribed
connection. After [`subscribe`](#subscribe) or [`psubscribe`](#psubscribe),
read the stream of pushed replies with [`next-message`](#next-message), which
turns each raw `RESP` value into one of these variants using
[`decode-message`](#decode-message).

```
(match (Redis.subscribe &r @\"news\")
  (Result.Success _)
    (match (Redis.next-message &r)
      (Result.Success msg)
        (match msg
          (PubSubMessage.Message channel payload)
            (println* \"got \" &payload \" on \" &channel)
          (PubSubMessage.Subscribe channel count)
            (println* \"subscribed to \" &channel)
          _ (println* \"other pub/sub reply\"))
      (Result.Error e) (IO.errorln &e))
  (Result.Error e) (IO.errorln &e))
```")
